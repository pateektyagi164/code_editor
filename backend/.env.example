APP_NAME=Code Collab
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://codecollab:codecollab@localhost:5435/codecollab
REDIS_URL=redis://localhost:6380/0

SECRET_KEY=prateekXaarchi
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173"]

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Judge0 code execution
# Public CE (works on Windows/macOS without Docker): https://ce.judge0.com
# Self-hosted (Linux recommended): http://localhost:2358  +  docker compose --profile judge0 up -d
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_TIMEOUT_SECONDS=60
EXECUTION_MAX_SOURCE_BYTES=65536

# AI — set LLM_PROVIDER to "openai" or "gemini"
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_TIMEOUT_SECONDS=120
